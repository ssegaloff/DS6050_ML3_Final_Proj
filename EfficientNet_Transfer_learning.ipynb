   "outputs": [],
   "source": [
    "from torch.nn import Module\n",
    "import torch.optim as optim\n",
    "import torch.nn as nn\n",
    "import timm"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4f2dc4b1",
   "metadata": {},
   "source": [
    "# Efficient Net B0 CNN"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "fbd90249",
   "metadata": {},
   "outputs": [],
   "source": [
    "class EffNetB0CNN(Module):\n",
    "    def __init__(self, num_classes = 4):\n",
    "        super(EffNetB0CNN, self).__init__()\n",
    "        self.model = timm.create_model('efficientnet_b0', pretrained=True, num_classes=num_classes)\n",
    "\n",
    "    def forward(self, X):\n",
    "      output = self.model(X)\n",
    "      return output\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "deec57bd",
